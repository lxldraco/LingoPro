    "aboutContent": {
      "html": "<div class='about-container'><h1>About LingoPro</h1><div class='app-info'><p><b>Version:</b> 1.2.0</p><p><b>Build Date:</b> July 14, 2025</p></div><div class='features'><h2>Features</h2><ul><li>Text analysis with OpenNLP</li><li>Advanced search capabilities</li><li>Context-aware result highlighting</li><li>Search history management</li></ul></div><div class='contact-info'><h2>Contact & Support</h2><p><b>Email:</b> support@LingoPro.com</p><p><b>Documentation:</b> docs.LingoPro.com</p><p><b>GitHub:</b> github.com/LingoPro</p></div><div class='team'><h2>Development Team: Group 14</h2><p>LingoPro is developed by Group 14</p><p>© 2025 LingoPro. All rights reserved.</p></div></div>",
